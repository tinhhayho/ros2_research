    </mxCell>
    <mxCell id="sdt-gloss3" value="CP = Classic Platform · AP = Adaptive Platform · ARXML = AUTOSAR XML configuration format · OSEK = the 1990s automotive RTOS standard behind CP's OS · MCAL = Microcontroller Abstraction Layer (vendor-supplied drivers) · UDS / COM /" style="text;html=1;align=center;verticalAlign=middle;fontSize=8.5;fontColor=#555555;" vertex="1" parent="1">
      <mxGeometry x="10" y="723" width="940" height="14" as="geometry" />
    </mxCell>
    <mxCell id="sdt-gloss4" value="NvM = the diagnostics, signal and storage module families · MMU = Memory Management Unit" style="text;html=1;align=center;verticalAlign=middle;fontSize=8.5;fontColor=#555555;" vertex="1" parent="1">
