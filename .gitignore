ws/build/
ws/install/
ws/log/

# resolved base-image digest (regenerated by capture_versions.sh;
# the value is also recorded — and committed — in VERSIONS.lock)
docker/image.env

# optional PDF export of the slides (HTML is the committed deliverable)
slides/slides.pdf

# PNG renders of the SVG diagrams (verification only; the .svg files are the source)
slides/assets/*.png

# python build noise
__pycache__/
*.pyc


# editor / OS noise
*.swp
*~
.DS_Store

